# kappy-engine — variáveis de ambiente
# Copia este ficheiro para .env e preenche os valores.
# NUNCA faças commit do .env (já está no .gitignore).

# ── Servidor ─────────────────────────────────────────────────
PORT=3001

# ── Google Apps Script (base de dados) ───────────────────────
SHEETS_URL=COLE_AQUI_O_URL_DO_APPS_SCRIPT
SHEETS_API_KEY=COLE_AQUI_A_TUA_API_KEY

# ── Provider de cotações de bolsa ────────────────────────────
# Opções disponíveis: brapi
STOCKS_PROVIDER=brapi

# ── brapi.dev (cotações B3) ───────────────────────────────────
# Regista em https://brapi.dev para obter um token gratuito
BRAPI_TOKEN=COLE_AQUI_O_TEU_TOKEN_BRAPI
